    "files.associations": {
        "*.yml": "yaml",
        "*.hcldec": "toml"
    },
    "githubPullRequests.fileListLayout": "flat",
    "githubPullRequests.pullBranch": "never",
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "sonarlint.connectedMode.connections.sonarcloud": [
        {
            "organizationKey": "hpe-hcss",
            "connectionId": "hpe-hcss",
            "disableNotifications": true
        }
    ],
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "githubIssues.queries": [
        {
            "label": "My Issues",
            "query": "is:open assignee:${user} repo:${owner}/${repository}",
            "groupBy": [
                "milestone"
            ]
        },
        {
            "label": "Created Issues",
            "query": "author:${user} state:open repo:${owner}/${repository} sort:created-desc"
        },
        {
            "label": "Recent Issues",
            "query": "state:open repo:${owner}/${repository} sort:updated-desc"
        }
    ],
    "githubPullRequests.pushBranch": "always",
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "gitlens.views.stashes.files.layout": "tree",
    "git.confirmForcePush": false,
    "github.copilot.advanced": {},
    "explorer.confirmDragAndDrop": false,
    "terminal.integrated.fontFamily": "'DejaVuSansM Nerd Font Mono'",
    "editor.fontFamily": "'DejaVuSansM Nerd Font Mono', 'monospace', monospace",
    "cSpell.dictionaries": [
        "golang"
    ],
    "terminal.integrated.fontSize": 15,
    "editor.minimap.renderCharacters": false,
    "github.copilot.editor.enableAutoCompletions": true,
    "editor.minimap.enabled": false,
    "diffEditor.renderSideBySide": true,
    "workbench.startupEditor": "none",
    "dev.containers.defaultExtensionsIfInstalledLocally": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "GitHub.vscode-pull-request-github"
    ],
    "dev.containers.dockerComposePath": "docker compose",
    "go.toolsManagement.autoUpdate": true,
    "remote.autoForwardPortsFallback": 0,
    "remote.otherPortsAttributes": {
        "requireLocalPort": true
    },
    "editor.rulers": [
        {
            "column": 128,
            "color": "#c66cdd6e",
            "name": "No indent"
        }
    ],
    "makefile.configureOnOpen": true,
    "editor.lineNumbers": "relative",
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    },
    "editor.unicodeHighlight.ambiguousCharacters": false
}
